<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- 文本样式 - 标题 -->
    <style name="Text.Title" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/背景_文字</item>
    </style>

    <style name="Text.Title.Large">
        <item name="android:textSize">28sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- 文本样式 - 副标题 -->
    <style name="Text.Subtitle" parent="TextAppearance.MaterialComponents.Subtitle1">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/背景_文字</item>
    </style>

    <style name="Text.Subtitle.Secondary">
        <item name="android:textColor">@color/次要文字</item>
    </style>

    <!-- 文本样式 - 正文 -->
    <style name="Text.Body" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/背景_文字</item>
    </style>

    <style name="Text.Body.Secondary">
        <item name="android:textColor">@color/次要文字</item>
    </style>

    <!-- 文本样式 - 按钮文字 -->
    <style name="Text.Button" parent="TextAppearance.MaterialComponents.Button">
        <item name="android:textSize">14sp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- 文本样式 - 标签文字 -->
    <style name="Text.Caption" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/次要文字</item>
    </style>

    <!-- 按钮样式 - 主要按钮 -->
    <style name="Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="android:background">@drawable/bg_button_primary</item>
        <item name="android:textColor">@color/白色</item>
        <item name="android:paddingVertical">12dp</item>
        <item name="android:paddingHorizontal">24dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:layout_margin">8dp</item>
    </style>

    <!-- 按钮样式 - 次要按钮 -->
    <style name="Button.Secondary" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">@color/主色</item>
        <item name="strokeColor">@color/主色</item>
        <item name="android:paddingVertical">12dp</item>
        <item name="android:paddingHorizontal">24dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:layout_margin">8dp</item>
    </style>

    <!-- 按钮样式 - 文字按钮 -->
    <style name="Button.Text" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/主色</item>
        <item name="android:textSize">14sp</item>
    </style>

    <!-- 输入框样式 -->
    <style name="EditText.Primary" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="android:background">@drawable/bg_button_primary</item>
        <item name="android:textColor">@color/背景_文字</item>
        <item name="android:padding">16dp</item>
        <item name="android:layout_margin">8dp</item>
    </style>

    <!-- 卡片样式 -->
    <style name="Card.Primary" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/表面</item>
        <item name="cardCornerRadius">8dp</item>
        <item name="cardElevation">4dp</item>
        <item name="android:layout_margin">8dp</item>
    </style>

    <style name="Card.Elevated" parent="Card.Primary">
        <item name="cardElevation">8dp</item>
    </style>

    <!-- 工具栏样式 -->
    <style name="Toolbar" parent="Widget.MaterialComponents.Toolbar.Primary">
        <item name="android:background">@color/主色</item>
        <item name="titleTextColor">@color/白色</item>
    </style>

    <!-- 对话框样式 -->
    <style name="Dialog" parent="ThemeOverlay.MaterialComponents.Dialog.Alert">
        <item name="colorPrimary">@color/主色</item>
        <item name="android:windowBackground">@color/表面</item>
        <item name="android:backgroundDimEnabled">true</item>
    </style>

    <!-- FAB样式 -->
    <style name="FAB" parent="Widget.MaterialComponents.FloatingActionButton">
        <item name="backgroundTint">@color/主色</item>
        <item name="tint">@color/白色</item>
    </style>

    <!-- Chip样式 -->
    <style name="Chip" parent="Widget.MaterialComponents.Chip.Choice">
        <item name="chipBackgroundColor">@color/主色_亮</item>
        <item name="android:textColor">@color/主色_文字</item>
    </style>
</resources>