<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- 分类颜色指示 -->
        <View
            android:id="@+id/view_color_indicator"
            android:layout_width="4dp"
            android:layout_height="0dp"
            android:background="@color/主色"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- 分类名称 -->
        <TextView
            android:id="@+id/tv_category_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="分类名称"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/背景_文字"
            android:layout_marginStart="12dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@id/view_color_indicator"
            app:layout_constraintEnd_toStartOf="@id/tv_todo_count" />

        <!-- 待办数量 -->
        <TextView
            android:id="@+id/tv_todo_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0个待办"
            android:textSize="12sp"
            android:textColor="@color/次要文字"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>
